---
import { Masonry } from "astro-masonry";
import FeaturedImage from "./FeaturedImage.astro";

import wedding1 from "@/assets/images/featured/wedding-1.jpg";
import wedding2 from "@/assets/images/featured/wedding-2.jpg";
import portrait1 from "@/assets/images/featured/portrait-1.jpg";
import portrait2 from "@/assets/images/featured/portrait-2.jpg";
import architectural1 from "@/assets/images/featured/architectural-1.jpg";
import architectural2 from "@/assets/images/featured/architectural-2.jpg";
import event1 from "@/assets/images/featured/event-1.jpg";
import event2 from "@/assets/images/featured/event-2.jpg";
import travel1 from "@/assets/images/featured/travel-1.jpg";
import travel2 from "@/assets/images/featured/travel-2.jpg";
import assignment1 from "@/assets/images/featured/assignment-1.jpg";
import assignment2 from "@/assets/images/featured/assignment-2.jpg";

const featuredItems = [
  {
    image: wedding1,
    alt: "Wedding photography in Arizona by Simon Wickes -- bride and groom during golden hour ceremony",
    category: "Weddings",
    href: "/services/weddings/",
  },
  {
    image: portrait1,
    alt: "Portrait photography in Arizona by Simon Wickes -- natural light portrait in a sunlit meadow",
    category: "Portraits",
    href: "/services/portraits/",
  },
  {
    image: architectural1,
    alt: "Architectural photography in Arizona by Simon Wickes -- sweeping property exterior at dawn",
    category: "Architectural",
    href: "/services/architectural/",
  },
  {
    image: travel1,
    alt: "Travel photography by Simon Wickes -- classic car in warm afternoon light",
    category: "Travel",
    href: "/services/travel/",
  },
  {
    image: assignment2,
    alt: "Assignment photography in Arizona by Simon Wickes -- professional brand photography",
    category: "Assignments",
    href: "/services/assignments/",
  },
  {
    image: event1,
    alt: "Event photography in Arizona by Simon Wickes -- candid moment at a corporate gathering",
    category: "Events",
    href: "/services/events/",
  },
  {
    image: event2,
    alt: "Event photography in Arizona by Simon Wickes -- musician captured mid-performance on stage",
    category: "Events",
    href: "/services/events/",
  },
  {
    image: assignment1,
    alt: "Assignment photography in Arizona by Simon Wickes -- editorial assignment for a local publication",
    category: "Assignments",
    href: "/services/assignments/",
  },
  {
    image: wedding2,
    alt: "Wedding photography in Arizona by Simon Wickes -- intimate couple portrait at a vineyard wedding",
    category: "Weddings",
    href: "/services/weddings/",
  },
  {
    image: portrait2,
    alt: "Portrait photography in Arizona by Simon Wickes -- expressive portrait against autumn foliage",
    category: "Portraits",
    href: "/services/portraits/",
  },
  {
    image: architectural2,
    alt: "Architectural photography in Arizona by Simon Wickes -- interior detail with natural light",
    category: "Architectural",
    href: "/services/architectural/",
  },
  {
    image: travel2,
    alt: "Travel photography by Simon Wickes -- detail shot of a vintage aircraft",
    category: "Travel",
    href: "/services/travel/",
  },
];
---

<Masonry
  breakpointCols={{
    default: 4,
    1100: 3,
    700: 2,
    500: 1,
  }}
  class="flex gap-4"
  columnClass=""
>
  {
    featuredItems.map((item) => (
      <div class="mb-4">
        <FeaturedImage
          image={item.image}
          alt={item.alt}
          category={item.category}
          href={item.href}
        />
      </div>
    ))
  }
</Masonry>
